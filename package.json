{
  "name": "docsafe-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "frontend:dev": "npm run dev -w frontend",
    "backend:dev": "npm run start:dev -w backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
